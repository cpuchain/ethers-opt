{
    "name": "ethers-opt",
    "version": "1.0.1",
    "description": "Collection of heavily optimized functions for ethers.js V6",
    "license": "MIT",
    "author": "CPUchain",
    "main": "./lib/index.js",
    "module": "./lib.esm/index.js",
    "types": "./lib/index.d.ts",
    "exports": {
        ".": {
            "import": "./lib.esm/index.js",
            "require": "./lib/index.js",
            "default": "./lib/index.js"
        },
        "./fixtures": {
            "import": "./lib.esm/fixtures/index.js",
            "require": "./lib/fixtures/index.js",
            "default": "./lib/fixtures/index.js"
        },
        "./prover": {
            "import": "./lib.esm/prover/index.js",
            "require": "./lib/prover/index.js",
            "default": "./lib/prover/index.js"
        }
    },
    "keywords": [
        "ethers",
        "ethereum",
        "web3",
        "dapp",
        "browser"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/cpuchain/ethers-opt.git"
    },
    "scripts": {
        "lint": "eslint scripts/**/*.ts src/**/*.ts test/**/*.ts --ignore-pattern src/typechain src/typechain-hardhat",
        "typechain:test": "hardhat clean && hardhat compile && hardhat flatten:all",
        "typechain": "yarn typechain:test && typechain --target ethers-v6 --out-dir src/typechain src/abi/*.json && ts-node scripts/typechain.ts",
        "types": "tsc -p tsconfig.types.json --declaration && tsc -p tsconfig.esm.json --declaration",
        "build": "yarn types && webpack",
        "syncEvents": "hardhat run ./scripts/syncEvents.ts",
        "deploy:token": "hardhat run ./scripts/deployToken.ts",
        "docs:dev": "vitepress dev docs",
        "docs:build": "vitepress build docs",
        "docs:preview": "vitepress preview docs",
        "test": "nyc mocha -r ts-node/register -r source-map-support/register --timeout 10000 --recursive test/**/*.ts && istanbul-badges-readme --colors=\"red:50,yellow:60\""
    },
    "dependencies": {
        "ethers": "^6.14.4"
    },
    "devDependencies": {
        "@cpuchain/eslint": "^1.0.5",
        "@cpuchain/logger": "^1.0.5",
        "@ethereumjs/mpt": "^10.0.0",
        "@ethereumjs/rlp": "^10.0.0",
        "@istanbuljs/nyc-config-typescript": "^1.0.2",
        "@nomicfoundation/hardhat-chai-matchers": "^2.0.9",
        "@nomicfoundation/hardhat-ethers": "^3.0.9",
        "@nomicfoundation/hardhat-ignition": "^0.15.12",
        "@nomicfoundation/hardhat-ignition-ethers": "^0.15.13",
        "@nomicfoundation/hardhat-network-helpers": "^1.0.13",
        "@nomicfoundation/hardhat-toolbox": "^6.0.0",
        "@nomicfoundation/hardhat-verify": "^2.0.14",
        "@openzeppelin/contracts": "^5.3.0",
        "@typechain/ethers-v6": "^0.5.1",
        "@typechain/hardhat": "^9.1.0",
        "@types/chai": "^5.2.2",
        "@types/mocha": "^10.0.10",
        "@types/node": "^22.15.32",
        "chai": "4.5.0",
        "esbuild-loader": "^4.3.0",
        "hardhat": "^2.25.0",
        "hardhat-gas-reporter": "^2.3.0",
        "hh-flatten": "^1.0.1",
        "idb": "^8.0.3",
        "istanbul-badges-readme": "^1.9.0",
        "nyc": "^17.1.0",
        "solidity-coverage": "^0.8.16",
        "solmate": "^6.8.0",
        "source-map-support": "^0.5.21",
        "ts-node": "^10.9.2",
        "tsc": "^2.0.4",
        "typechain": "^8.3.2",
        "typescript": "^5.8.3",
        "vitepress": "^1.6.3",
        "webpack": "^5.99.9",
        "webpack-cli": "^6.0.1"
    },
    "resolutions": {
        "cookie": "^0.7.1",
        "fast-glob": ">=3.3.3"
    }
}